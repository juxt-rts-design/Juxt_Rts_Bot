# Configuration du Bot WhatsApp Aquila
# Copiez ce fichier vers .env et remplissez vos valeurs

# Clé API Gemini (obligatoire pour l'IA)
# Obtenez votre clé sur : https://console.cloud.google.com/
GEMINI_API_KEY=votre_cle_api_gemini_ici

# Clé API Météo (optionnelle, pour données météo réelles)
# Obtenez votre clé sur : https://openweathermap.org/api
WEATHER_API_KEY=votre_cle_api_meteo_ici

# Dossier de session WhatsApp (stockage des données d'authentification)
SESSION_DIR=./auth_info

# Port du serveur Express
PORT=3000

# Configuration du fallback JSON
FALLBACK_JSON_PATH=./fallback_responses.json
FALLBACK_ENABLED=true

# Contact du créateur (format WhatsApp)
CREATOR_CONTACT=+241076234942@s.whatsapp.net

# Préfixe des commandes
PREFIX=-

# Configuration des médias
IMAGES_DIR=./images
VIDEOS_DIR=./videos

# Configuration de logging
LOG_LEVEL=info

# Configuration du serveur
NODE_ENV=development

# Timeout pour les requêtes Gemini (en millisecondes)
GEMINI_TIMEOUT=30000

# Nombre maximum de tentatives Gemini avant fallback
MAX_GEMINI_RETRIES=2

# Activation du mode debug
DEBUG=false
