  "description": "Bot WhatsApp intelligent avec système de fallback JSON pour les réponses informatiques",
  "main": "server_with_fallback.js",
  "scripts": {
    "start": "node bot_with_fallback.js",
    "server": "node server_with_fallback.js",
    "bot": "node bot_with_fallback.js",
    "dev": "nodemon server_with_fallback.js",
    "test": "node test_fallback.js",
