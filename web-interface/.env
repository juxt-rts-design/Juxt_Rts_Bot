# Configuration de l'interface web JUXT_RTS Bot

# Port du serveur web
PORT=3000

# Chemin vers le bot principal
BOT_PATH=../bot_with_fallback.js

# Dossier des sessions
SESSION_DIR=../auth_info

# Configuration WebSocket
WS_PORT=3000

# Configuration de sécurité
ALLOWED_ORIGINS=http://localhost:3000

# Configuration du bot
BOT_NAME=JUXT_RTS Bot
BOT_VERSION=1.0.0

# Logs
LOG_LEVEL=info
LOG_FILE=logs/web-interface.log

# Configuration des sessions
SESSION_TIMEOUT=300000
MAX_SESSIONS=10

# Configuration QR Code
QR_SIZE=300
QR_MARGIN=2

# Configuration des codes de liaison
PAIRING_CODE_LENGTH=6
PAIRING_CODE_TIMEOUT=60000
